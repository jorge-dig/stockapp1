# ── MySQL (Docker) ──────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=stockapp
MYSQL_USER=stockuser
MYSQL_PASSWORD=stockpass
MYSQL_ROOT_PASSWORD=stockroot

# ── Telegram Bot ─────────────────────────────────
# 1. Create a bot via @BotFather on Telegram → get token
# 2. Send a message to your bot, then fetch chat_id via:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scheduler ────────────────────────────────────
# Hour and minute (24h) in SCHEDULE_TZ timezone when the daily pipeline runs
SCHEDULE_HOUR=18
SCHEDULE_MINUTE=5
SCHEDULE_TZ=America/New_York

# ── Alpha Vantage (optional backup) ──────────────
ALPHA_VANTAGE_KEY=
